# Admin password for the /admin panel
# Replace with a strong password before deploying
ADMIN_PASSWORD=change-me-to-a-strong-password

# Secret used to sign the admin session cookie
# Must be at least 32 characters long
ADMIN_COOKIE_SECRET=change-this-to-a-random-32-char-string-minimum

# Optional: Set your production base URL for redirects
# NEXT_PUBLIC_BASE_URL=https://your-domain.com

# Contact form — email delivery via Resend (https://resend.com)
# 1. Sign up at resend.com (free — 3 000 emails/month)
# 2. Create an API key and paste it below
# 3. Set CONTACT_EMAIL to the inbox where you want messages delivered
RESEND_API_KEY=re_your_api_key_here
CONTACT_EMAIL=you@example.com
